{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "flow": {
      "type": "local",
      "command": ["flow-mcp"],
      "enabled": true,
      "environment": {
        "FLOW_LOG_LEVEL": "INFO"
      },
      "timeout": 30000
    }
  },
  "permission": {
    "flow_run_workflow": "ask"
  }
}
